{
  "name": "ouroboros",
  "version": "1.3.16",
  "description": "Electron desktop app for launching and monitoring Claude Code sessions",
  "author": "Ouroboros",
  "main": "out/main/index.js",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "clean": "rm -rf out dist coverage .vite",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:analyze": "node -e \"require('child_process').execSync('electron-vite build',{stdio:'inherit',env:{...process.env,ANALYZE:'true'}})\"",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "pretest": "node scripts/kill-stale-vitest.mjs && node scripts/install-sqlite-fresh.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=electron",
    "test:mobile": "playwright test --project=mobileWeb-iphone --project=mobileWeb-pixel",
    "knip": "knip",
    "licenses": "generate-license-file --input package.json --output THIRD_PARTY_LICENSES --overwrite",
    "depcheck": "depcheck",
    "audit:prod": "npm audit --omit=dev",
    "audit:snapshot": "node scripts/audit-snapshot-safety.mjs",
    "bench:indexer": "node scripts/benchmark-indexer.mjs",
    "validate": "npm run typecheck && npm run format:check && npm run lint && npm run test",
    "build:web": "vite build -c vite.web.config.ts && vite build -c vite.webpreload.config.ts",
    "cap:sync": "cap sync",
    "cap:android": "cap open android",
    "cap:build:android": "npm run build:web && cap sync android",
    "cap:build:android:release": "node ./tools/build-android-release.js",
    "cap:build:android:debug": "npm run build:web && cap sync android",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3,node-pty",
    "postinstall": "electron-rebuild -f -w better-sqlite3,node-pty"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@capacitor-mlkit/barcode-scanning": "6.2.0",
    "@capacitor/android": "6.2.1",
    "@capacitor/app": "6.0.3",
    "@capacitor/cli": "6.2.1",
    "@capacitor/core": "6.2.1",
    "@capacitor/haptics": "6.0.3",
    "@capacitor/keyboard": "6.0.4",
    "@capacitor/preferences": "6.0.4",
    "@capacitor/share": "6.0.4",
    "@capacitor/splash-screen": "6.0.2",
    "@capacitor/status-bar": "6.0.3",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-wast": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.17",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@node-rs/xxhash": "^1.7.6",
    "@parcel/watcher": "^2.5.6",
    "@tanstack/react-virtual": "^3.13.23",
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "@xenova/transformers": "^2.17.2",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-progress": "^0.2.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode-graphemes": "^0.4.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.8.0",
    "dompurify": "^3.2.2",
    "electron-log": "^5.4.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.0",
    "express": "^5.2.1",
    "fuse.js": "^7.0.0",
    "ignore": "^7.0.5",
    "immer": "^11.1.4",
    "mica-electron": "^1.5.17",
    "monaco-editor": "^0.55.1",
    "monaco-vim": "^0.4.4",
    "node-pty": "^1.2.0-beta.11",
    "pdfjs-dist": "^5.5.207",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "rich-textarea": "^0.27.0",
    "shiki": "^3.0.0",
    "streamdown": "^2.5.0",
    "tree-sitter-wasms": "^0.1.13",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "web-tree-sitter": "^0.22.6",
    "ws": "^8.19.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.0",
    "axe-core": "^4.11.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "depcheck": "^1.4.7",
    "electron": "^41.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "generate-license-file": "^4.1.1",
    "jsdom": "^29.0.1",
    "knip": "^5.87.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.0",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vitest": "^4.0.0",
    "vitest-axe": "^0.1.0"
  },
  "build": {
    "appId": "com.arcflow.ouroboros",
    "productName": "Ouroboros",
    "copyright": "Copyright © 2025-2026 Ouroboros",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "out/**/*",
      "THIRD_PARTY_LICENSES",
      "!**/*.map",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin"
    ],
    "npmRebuild": false,
    "asarUnpack": [
      "**/node_modules/node-pty/**",
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/@vscode/tree-sitter-wasm/**",
      "**/node_modules/web-tree-sitter/**",
      "**/node_modules/tree-sitter-wasms/**",
      "**/node_modules/@parcel/watcher/**",
      "**/node_modules/@parcel/watcher-*/**",
      "**/node_modules/@node-rs/xxhash*/**"
    ],
    "extraResources": [
      {
        "from": "src/main/shellIntegration",
        "to": "shellIntegration",
        "filter": [
          "*.sh",
          "*.ps1"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.ico",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "forceCodeSigning": false,
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ouroboros",
      "installerIcon": "build-resources/icon.ico",
      "uninstallerIcon": "build-resources/icon.ico"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build-resources/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build-resources/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "hesnotsoharry",
      "repo": "Ouroboros",
      "releaseType": "release"
    }
  }
}
