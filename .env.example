# Anthropic API key (optional — falls back to OAuth authentication via ~/.claude/.credentials.json)
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub OAuth App Client ID (required for GitHub authentication)
# Create at: https://github.com/settings/developers → New OAuth App
# GITHUB_CLIENT_ID=Ov23li...

# Default shell override (optional — falls back to $SHELL env var, then /bin/bash)
# SHELL=/bin/zsh
