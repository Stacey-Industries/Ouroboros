{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -NonInteractive -File \"C:\\Web App\\Agent IDE\\assets\\hooks\\pre_commit_lint.ps1\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -NonInteractive -File \"C:\\Web App\\Agent IDE\\assets\\hooks\\post_edit_eslint.ps1\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -NonInteractive -File \"C:\\Web App\\Agent IDE\\assets\\hooks\\post_edit_test.ps1\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -NonInteractive -File \"C:\\Web App\\Agent IDE\\assets\\hooks\\post_write_test_required.ps1\""
          }
        ]
      }
    ]
  }
}