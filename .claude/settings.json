{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\Web App\\Agent IDE\\assets\\hooks\\pre_commit_lint.mjs\""
          },
          {
            "type": "command",
            "command": "node \"C:\\Web App\\Agent IDE\\assets\\hooks\\pre_push_full_check.mjs\""
          },
          {
            "type": "command",
            "command": "node \"C:\\Web App\\Agent IDE\\assets\\hooks\\pre_commit_secrets.mjs\""
          },
          {
            "type": "command",
            "command": "node \"C:\\Web App\\Agent IDE\\assets\\hooks\\pre_commit_message.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\Web App\\Agent IDE\\assets\\hooks\\post_edit_eslint.mjs\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\Web App\\Agent IDE\\assets\\hooks\\post_edit_test.mjs\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:\\Web App\\Agent IDE\\assets\\hooks\\post_write_test_required.mjs\""
          }
        ]
      }
    ]
  }
}
