#!/bin/sh
# Wave 92 Phase 4 — pre-push hook.
#
# Blocks any push that modifies package-lock.json without a valid
# .lockfile-sync.marker (i.e. the change didn't come through `npm run lockfile:sync`).
#
# Install once per clone:
#   git config core.hooksPath scripts/hooks
#
# Advisory bypass: set LOCKFILE_SYNC_GUARD_BYPASS=1 to skip the check.
#   LOCKFILE_SYNC_GUARD_BYPASS=1 git push
#
# How it works:
#   git push feeds this hook via stdin with lines of:
#     <local-ref> <local-sha> <remote-ref> <remote-sha>
#   For each ref being pushed, we diff local..remote for package-lock.json.
#   If any ref touches it, we run `npm run lockfile:check`.
#   The LOCKFILE_SYNC_GUARD_BYPASS env passes through to lockfile:check automatically.

REMOTE="$1"
# REMOTE_URL="$2"  # available but not needed

ZERO_SHA="0000000000000000000000000000000000000000"

lockfile_touched=0

while read local_ref local_sha remote_ref remote_sha; do
  # Skip branch deletions (local_sha is zeros) — nothing being pushed.
  if [ "$local_sha" = "$ZERO_SHA" ]; then
    continue
  fi

  if [ "$remote_sha" = "$ZERO_SHA" ]; then
    # New ref (no upstream yet) — walk the entire local history for this ref
    # to detect any commit touching package-lock.json.
    changed=$(git log --name-only --format="" "${local_sha}" -- package-lock.json 2>/dev/null | grep -c 'package-lock.json' || true)
  else
    # Existing upstream — diff only the commits being pushed.
    changed=$(git diff --name-only "${remote_sha}..${local_sha}" -- package-lock.json 2>/dev/null | grep -c 'package-lock.json' || true)
  fi

  if [ "$changed" -gt 0 ]; then
    lockfile_touched=1
    break
  fi
done

if [ "$lockfile_touched" -eq 1 ]; then
  npm run lockfile:check
  exit $?
fi

exit 0
